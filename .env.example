# Supabase Postgres connection string.
# Get this from Supabase Dashboard → Project Settings → Database → Connection string → URI.
# Use the "Transaction" pooler (port 6543) for runtime / Vercel functions.
DATABASE_URL=

# Direct (non-pooled) connection string, used only for running migrations from drizzle-kit.
# Get this from the same page using "Direct connection" (port 5432). Optional in dev — if unset,
# DATABASE_URL is used as a fallback.
DIRECT_DATABASE_URL=

# Password gate for the web UI. Pick something long.
APP_PASSWORD=

# 32+ char random secret used to sign the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=

# Bearer token used by the property bookmarklet to authenticate to /api/properties.
# Different from APP_PASSWORD because the bookmarklet has to embed this in plain JS.
# Generate the same way as SESSION_SECRET.
BOOKMARKLET_TOKEN=

# Anthropic API key. Used to extract structured property data from page HTML
# via Claude. Get one at https://console.anthropic.com/settings/keys.
ANTHROPIC_API_KEY=
